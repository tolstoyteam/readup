{
  "name": "readup",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "mobile": "pnpm --filter @readup/mobile start",
    "admin": "pnpm --filter @readup/admin dev",
    "db:generate": "pnpm --filter @readup/db generate",
    "db:migrate": "pnpm --filter @readup/db migrate",
    "db:apply-drizzle": "pnpm --filter @readup/db apply-drizzle",
    "db:studio": "pnpm --filter @readup/db studio",
    "db:push": "pnpm --filter @readup/db push",
    "db:sql": "pnpm --filter @readup/db sql"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
